<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.maldaze.morning-agent</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/sh</string>
        <string>-c</string>
        <string>sleep 5 &amp;&amp; curl -s -X POST http://127.0.0.1:8765/api/morning-briefing</string>
    </array>

    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>8</integer>
        <key>Minute</key>
        <integer>0</integer>
    </dict>

    <key>RunAtLoad</key>
    <true/>

    <key>StandardOutPath</key>
    <string>LOG_DIR_PLACEHOLDER/maldaze-morning-agent.log</string>

    <key>StandardErrorPath</key>
    <string>LOG_DIR_PLACEHOLDER/maldaze-morning-agent-error.log</string>
</dict>
</plist>
